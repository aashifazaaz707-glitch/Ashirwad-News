---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsCard from '../../components/NewsCard.astro';

export async function getStaticPaths() {
  const categories = [
    'breaking',
    'musrigharari',
    'samastipur',
    'bihar',
    'india',
    'world',
    'politics'
  ];
  return categories.map(category => ({
    params: { category }
  }));
}

const { category } = Astro.params;

// Fetch all news and filter by category
const allNews = await getCollection('news');
const filteredNews = allNews
  .filter(item => item.data.category === category)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Category translations
const categoryLabels: Record<string, string> = {
  breaking: 'ताजा खबर',
  musrigharari: 'मुसरीघरारी',
  samastipur: 'समस्तीपुर',
  bihar: 'बिहार',
  india: 'देश',
  world: 'दुनिया',
  politics: 'राजनीति'
};

const categoryTitle = categoryLabels[category] || category;
---

<Layout title={`${categoryTitle} - समाचार`}>
  <Header />

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 py-8">
    <div class="space-y-6">
      
      <!-- Category Heading banner -->
      <div class="border-b border-gray-100 pb-4 flex items-center justify-between">
        <div class="space-y-1">
          <h2 class="text-2xl sm:text-3xl font-extrabold text-brand-dark flex items-center gap-2">
            <span class="inline-block w-3 h-7 bg-brand-red rounded-sm"></span>
            {categoryTitle}
          </h2>
          <p class="text-xs text-gray-400 font-medium">
            {categoryTitle} श्रेणी में ताज़ा तरीन और निष्पक्ष समाचार
          </p>
        </div>
        <span class="text-xs font-bold text-gray-500 bg-gray-100 border border-gray-200 px-3 py-1 rounded-full font-heading">
          कुल समाचार: {filteredNews.length}
        </span>
      </div>

      <!-- Articles list grid -->
      {filteredNews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {filteredNews.map(item => (
            <NewsCard
              title={item.data.title}
              slug={item.slug}
              category={item.data.category}
              publishDate={item.data.publishDate}
              image={item.data.image}
            />
          ))}
        </div>
      ) : (
        <div class="py-20 text-center space-y-3 bg-white border border-gray-100 rounded-2xl shadow-inner">
          <div class="w-16 h-16 bg-gray-50 border border-gray-100 text-gray-400 rounded-full flex items-center justify-center mx-auto shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-newspaper"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
          </div>
          <p class="text-sm font-bold text-brand-charcoal">इस श्रेणी में अभी कोई समाचार उपलब्ध नहीं है।</p>
          <p class="text-xs text-gray-400">जल्द ही नए समाचार प्रकाशित किए जाएंगे, कृपया बने रहें।</p>
          <a href="/" class="inline-block text-xs font-bold text-white bg-brand-red hover:bg-brand-darkRed px-4 py-2 rounded-lg shadow transition-all">
            मुख्य पृष्ठ पर जाएं
          </a>
        </div>
      )}

    </div>
  </main>

  <Footer />
</Layout>
