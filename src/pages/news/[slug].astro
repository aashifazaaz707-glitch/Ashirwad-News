---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Fetch other recent news for sidebar
const allNews = await getCollection('news');
const recentNews = allNews
  .filter(item => item.slug !== post.slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);

// Category translations
const categoryLabels: Record<string, string> = {
  home: 'मुख्य पृष्ठ',
  breaking: 'ताजा खबर',
  musrigharari: 'मुसरीघरारी',
  samastipur: 'समस्तीपुर',
  bihar: 'बिहार',
  india: 'देश',
  world: 'दुनिया',
  politics: 'राजनीति'
};

const categoryLabel = categoryLabels[post.data.category] || post.data.category;

// Formatted Date
const formattedDate = post.data.publishDate.toLocaleDateString('hi-IN', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hour12: true
});

// Split tags by comma
const tagsList = post.data.tags 
  ? post.data.tags.split(',').map(tag => tag.trim()).filter(Boolean) 
  : [];
---

<Layout 
  title={post.data.title} 
  description={post.body.slice(0, 150)}
  image={post.data.image}
>
  <Header />

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- Article Left Column -->
      <article class="lg:col-span-8 bg-white border border-gray-100 rounded-2xl p-5 sm:p-8 shadow-sm space-y-6">
        
        <!-- Breadcrumb / Category Tag -->
        <div class="flex flex-wrap items-center gap-2 text-xs">
          <a href="/" class="text-gray-400 hover:text-brand-red font-medium">होम</a>
          <span class="text-gray-300 font-bold">/</span>
          <a href={`/category/${post.data.category}`} class="text-brand-red hover:underline font-bold uppercase">
            {categoryLabel}
          </a>
        </div>

        <!-- Headline Title -->
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-brand-dark leading-tight font-sans">
          {post.data.title}
        </h1>

        <!-- Article Meta Metadata -->
        <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500 py-3 border-y border-gray-100 font-medium">
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user text-brand-red"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>आशीर्वाद डेस्क</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock text-brand-red"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{formattedDate}</span>
          </div>
        </div>

        <!-- Featured Image -->
        {post.data.image && (
          <div class="rounded-xl overflow-hidden bg-gray-100 aspect-video relative shadow-sm">
            <Image
              src={post.data.image}
              alt={post.data.title}
              width={800}
              height={450}
              format="webp"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        )}

        <!-- Main Body Content -->
        <div class="article-content text-gray-800 leading-relaxed font-sans text-base sm:text-lg space-y-4">
          <Content />
        </div>

        <!-- Tags pills section -->
        {tagsList.length > 0 && (
          <div class="pt-6 border-t border-gray-100 space-y-2.5">
            <h4 class="text-xs font-extrabold text-brand-dark uppercase tracking-wider font-heading">
              टैग्स (Tags):
            </h4>
            <div class="flex flex-wrap gap-2">
              {tagsList.map(tag => (
                <a 
                  href={`/category/samastipur`}
                  class="text-xs font-semibold text-gray-600 bg-gray-50 border border-gray-100 px-3 py-1 rounded-full hover:bg-brand-red/5 hover:text-brand-red hover:border-brand-red/30 transition-all"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}

      </article>

      <!-- Sidebar Right Column -->
      <aside class="lg:col-span-4 space-y-6">
        
        <!-- Widget: Recent News list -->
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm space-y-4">
          <h3 class="text-lg font-bold font-heading text-brand-dark border-l-4 border-brand-red pl-2.5">
            ताज़ा समाचार
          </h3>
          <div class="space-y-4">
            {recentNews.map(item => (
              <a href={`/news/${item.slug}`} class="block group">
                <div class="flex gap-3 items-start">
                  {item.data.image && (
                    <div class="w-16 h-12 rounded-lg overflow-hidden shrink-0 bg-gray-100">
                      <Image 
                        src={item.data.image}
                        alt={item.data.title}
                        width={80}
                        height={60}
                        format="webp"
                        class="w-full h-full object-cover group-hover:scale-105 duration-300"
                      />
                    </div>
                  )}
                  <div class="space-y-1 min-w-0">
                    <h4 class="text-xs font-bold text-gray-800 leading-snug group-hover:text-brand-red line-clamp-2">
                      {item.data.title}
                    </h4>
                    <span class="text-[9px] text-gray-400 block">
                      {item.data.publishDate.toLocaleDateString('hi-IN', { month: 'short', day: 'numeric' })}
                    </span>
                  </div>
                </div>
              </a>
            ))}
            {recentNews.length === 0 && (
              <p class="text-xs text-gray-400 text-center py-2">कोई अन्य हालिया खबर नहीं है।</p>
            )}
          </div>
        </div>

        <!-- Widget: Ad / Notice Board banner -->
        <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center shadow-inner space-y-3">
          <span class="inline-block bg-gray-200 text-gray-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase font-heading tracking-wider">
            विज्ञापन
          </span>
          <div class="h-48 rounded-lg bg-gray-100 flex items-center justify-center border border-dashed border-gray-300 text-xs text-gray-400 font-semibold p-4">
            आशीर्वाद न्यूज़ विज्ञापन के लिए संपर्क करें: ads@ashirwadnews.com
          </div>
        </div>

      </aside>

    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Markdown styling styles for standard output */
  .article-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }
  .article-content h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
    border-left: 4px solid #d32f2f;
    padding-left: 0.75rem;
  }
  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1f2937;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .article-content ul, .article-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style-type: disc;
  }
  .article-content li {
    margin-bottom: 0.5rem;
  }
  .article-content a {
    color: #d32f2f;
    text-decoration: underline;
    font-weight: 600;
  }
  .article-content a:hover {
    color: #7f1d1d;
  }
  .article-content blockquote {
    border-left: 4px solid #d32f2f;
    background-color: #fef2f2;
    padding: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>
