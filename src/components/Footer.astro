---
const currentYear = new Date().getFullYear();

const categories = [
  { label: 'मुख्य पृष्ठ', path: '/' },
  { label: 'ताजा खबर', path: '/category/breaking' },
  { label: 'समस्तीपुर', path: '/category/samastipur' },
  { label: 'मुसरीघरारी', path: '/category/musrigharari' },
  { label: 'बिहार', path: '/category/bihar' },
  { label: 'देश', path: '/category/india' },
  { label: 'दुनिया', path: '/category/world' },
  { label: 'राजनीति', path: '/category/politics' }
];
---

<footer class="bg-brand-dark text-gray-300 pt-12 pb-6 border-t-4 border-brand-red mt-auto">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
    
    <!-- Column 1: Brand Intro -->
    <div class="space-y-4">
      <h3 class="text-xl font-bold font-heading text-white border-b border-brand-red/30 pb-2">
        ASHIRWAD NEWS
      </h3>
      <p class="text-sm text-gray-400 leading-relaxed font-sans">
        आशीर्वाद न्यूज़ समस्तीपुर, बिहार का अग्रणी हिंदी समाचार पोर्टल है। हम आपको निष्पक्ष, सटीक और त्वरित ख़बरें प्रदान करने के लिए प्रतिबद्ध हैं।
      </p>
      <div class="flex space-x-3 pt-2">
        <!-- Social Icons (Facebook, YouTube, Twitter) -->
        <a href="#" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-red text-white transition-colors" aria-label="Facebook">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
        <a href="#" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-red text-white transition-colors" aria-label="YouTube">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.528 3.545 12 3.545 12 3.545s-7.528 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.022 0 12 0 12s0 3.978.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.86.508 9.388.508 9.388.508s7.528 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.978 24 12 24 12s0-3.978-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="#" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-red text-white transition-colors" aria-label="Twitter">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Categories Grid -->
    <div class="space-y-4 md:col-span-2">
      <h3 class="text-xl font-bold font-heading text-white border-b border-brand-red/30 pb-2">
        श्रेणियां (Categories)
      </h3>
      <div class="grid grid-cols-2 gap-2 text-sm">
        {categories.map((cat) => (
          <a href={cat.path} class="hover:text-brand-accent flex items-center gap-1.5 hover:translate-x-1 duration-150">
            <span class="text-brand-red font-bold">»</span> {cat.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Column 3: Contact & Meta -->
    <div class="space-y-4">
      <h3 class="text-xl font-bold font-heading text-white border-b border-brand-red/30 pb-2">
        हमसे संपर्क करें
      </h3>
      <ul class="text-sm space-y-2.5">
        <li class="flex items-start gap-2 text-gray-400">
          <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span>मुसरीघरारी चौराहा, समस्तीपुर, बिहार - 848101</span>
        </li>
        <li class="flex items-center gap-2 text-gray-400">
          <svg class="w-4 h-4 text-brand-red shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span>+91 XXXXXXXXXX</span>
        </li>
        <li class="flex items-center gap-2 text-gray-400">
          <svg class="w-4 h-4 text-brand-red shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span>info@ashirwadnews.com</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-gray-800 pt-6 max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500 gap-4">
    <p>© {currentYear} आशीर्वाद न्यूज़। सर्वाधिकार सुरक्षित।</p>
    <div class="flex space-x-4">
      <a href="#" class="hover:text-brand-red">नियम एवं शर्तें</a>
      <a href="#" class="hover:text-brand-red">गोपनीयता नीति</a>
      <a href="/admin" class="hover:text-brand-red font-semibold">एडमिन लॉगिन</a>
    </div>
  </div>
</footer>
